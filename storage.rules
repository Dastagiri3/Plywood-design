rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // ─── Product images ───────────────────────────────────────────────────────
    // Only admins can upload/delete. Anyone can read (for public product images).
    match /products/{imageFile} {
      allow read: if true;
      allow create: if isAdmin() && isImage() && isUnder5MB();
      allow delete: if isAdmin();
      allow update: if false; // Use create + delete to replace
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
