rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Products ────────────────────────────────────────────────────────────
    // Anyone can read products; only admins can write.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Inquiries ───────────────────────────────────────────────────────────
    // Anyone (even unauthenticated) can create an inquiry.
    // Only admins can read and update inquiry status.
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update: if isAdmin();
      allow delete: if false; // never delete inquiries
    }

    // ─── Admins ──────────────────────────────────────────────────────────────
    // Admin documents are read-only from the client (managed via Firebase Console
    // or Admin SDK). Only existing admins can add new admins.
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
